---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
import Layout from '../layouts/Layout.astro';
import TeamMember from '../components/TeamMember.astro';

const team = [
  {
    name: "Abdullah Khokhar",
    title: "Co-Founder",
    bio: "Passionate about Technology and Business, and how they come together.",
    image: `${base}/images/avatar-1.jpg`
  },
  {
    name: "Vineeth Godavarti",
    title: "Co-Founder",
    bio: "Passionate about STEM and hands-on learning.",
    image: `${base}/images/avatar-2.jpg`
  },
  {
    name: "Aashrith Ram",
    title: "Co-Founder",
    bio: "Passionate about business and building long lasting connections with people.",
    image: `${base}/images/avatar-3.jpg`
  }
];

const values = [
  {
    title: "Equity",
    text: "Every student deserves access to high-quality STEM education.",
    icon: `${base}/images/icon-equity.svg`
  },
  {
    title: "Innovation",
    text: "We constantly evolve our teaching methods to stay current with tech trends.",
    icon: `${base}/images/icon-innovation.svg`
  },
  {
    title: "Community",
    text: "True impact requires deep collaboration with local educators and families.",
    icon: `${base}/images/icon-community.svg`
  }
];
---

<Layout title="About Us">
  <div class="page-header section section-alt text-center">
    <div class="container">
      <h1>About Us</h1>
      <p class="subtitle">Discover our story and the team behind the mission.</p>
    </div>
  </div>

  <section class="section">
    <div class="container content-grid">
      <div class="story-content">
        <h2>Our Story</h2>
        <!-- REPLACE: Our Story text -->
        <p>
          Founded in 2024, we wanted to provide students with the tools and knowledge to not only learn STEM, but to be able to apply it in the real world, with real use cases.
        </p>
        <p>
          We go further than most STEM programs by providing students with the opportunity to learn about entrepreneurship, business, and how to apply their STEM knowledge in real-world scenarios. Things like interview prep, public speaking, and business fundamentals are all part of our curriculum, which is designed to prepare students for the future.
        </p>
      </div>
      <div class="story-image">
        <!-- REPLACE: Our Story image -->
        <img src={`${base}/images/about-story.png`} alt="Students collaborating" width="500" height="350" class="rounded-img" />
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="text-center mb-lg">Our Values</h2>
      <div class="values-grid">
        {values.map(val => (
          <div class="value-card">
            <!-- REPLACE: Value icon -->
            <h3>{val.title}</h3>
            <p>{val.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="text-center mb-lg">Meet the Team</h2>
      <div class="team-grid">
        {team.map(member => (
          <TeamMember {...member} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .content-grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  .rounded-img {
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
    width: 100%;
    height: auto;
  }

  .mb-lg {
    margin-bottom: var(--spacing-xl);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }

  .value-card {
    background-color: var(--color-bg);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
    text-align: center;
  }

  .value-icon {
    margin: 0 auto var(--spacing-md);
    display: block;
    filter: invert(47%) sepia(85%) saturate(350%) hue-rotate(75deg) brightness(92%) contrast(85%); /* approximate primary color */
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }
</style>
