---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const logos = Array.from({ length: 3 }).map((_, i) => ({
  alt: `Partner Organization ${i + 1}`,
  src: `/images/partner-${i + 1}.svg`
}));
---

<section class="section partner-section">
  <div class="container">
    <h2 class="text-center sr-only">Our Partners</h2>
    <p class="text-center text-muted partner-intro">Trusted by leading organizations across the world</p>
    
    <div class="logo-grid">
      <div class="logo-item">
        <!-- REPLACE: Partner logos. Links can be wrapped around images -->
        <img src='/images/partner-Akanksha.png' alt='' width="120" height="120" loading="lazy" />
        <img src='/images/partner-Lightyear Foundation.png' alt='' width="120" height="120" loading="lazy" />
        <img src='/images/partner-Faith Academy.png' alt='' width="120" height="120" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .partner-section {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .partner-intro {
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--spacing-lg);
    align-items: center;
    justify-items: center;
  }

  .logo-item img {
    filter: grayscale(100%) opacity(0.7);
    transition: all 0.3s ease;
    max-height: 100px;
    width: auto;
  }

  .logo-item:hover img, .logo-item:focus-within img {
    filter: grayscale(0%) opacity(1);
  }
</style>
