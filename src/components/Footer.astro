---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-col">
      <h3>ExciteStem</h3>
      <!-- REPLACE: Org short description -->
      <p>Empowering the next generation of innovators through accessible STEM education for all.</p>
    </div>
    
    <div class="footer-col">
      <h3>Contact Us</h3>
      <ul class="contact-info">
        <!-- REPLACE: Contact Details -->
        <li>Email: info@excitestem.org</li>
        <li>Phone: (555) 123-4567</li>
        <li>123 Education Way<br>Learning City, ST 12345</li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Follow Us</h3>
      <div class="social-links">
        <!-- REPLACE: Social media links and icons -->
        <a href="#" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
        </a>
        <a href="#" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom container">
    <p>&copy; {currentYear} ExciteStem. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-xl);
  }

  .footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .footer-col h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-heading);
  }

  .contact-info {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--color-text-muted);
  }

  .contact-info li {
    margin-bottom: var(--spacing-sm);
  }

  .social-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    transition: all 0.2s ease;
  }

  .social-links a:hover, .social-links a:focus {
    background-color: var(--color-primary);
    color: white;
  }

  .footer-bottom {
    text-align: center;
    padding: var(--spacing-md) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
