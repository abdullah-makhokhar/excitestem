---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-col">
      <h3>ExciteSTEM</h3>
      <!-- REPLACE: Org short description -->
      <p>Empowering the next generation of innovators through accessible STEM education for all.</p>
    </div>
    
    <div class="footer-col">
      <h3>Contact Us</h3>
      <ul class="contact-info">
        <!-- REPLACE: Contact Details -->
        <li>Email: excitestem@gmail.com</li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom container">
    <p>&copy; {currentYear} ExciteSTEM. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-xl);
  }

  .footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .footer-col h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-heading);
  }

  .contact-info {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--color-text-muted);
  }

  .contact-info li {
    margin-bottom: var(--spacing-sm);
  }

  .social-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    transition: all 0.2s ease;
  }

  .social-links a:hover, .social-links a:focus {
    background-color: var(--color-primary);
    color: white;
  }

  .footer-bottom {
    text-align: center;
    padding: var(--spacing-md) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
